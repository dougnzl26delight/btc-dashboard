# Crypto Trading credentials
# Copy this file to .env and fill in real values. Never commit .env.

# ── Broker (pick ONE primary, optionally a second for cross-venue arb) ──

# Coinbase Advanced Trade API (recommended starting point)
# Sign up at https://www.coinbase.com/cloud/products/advanced-trade
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_PASSPHRASE=

# Kraken (alternative — better for futures, funding data)
# https://www.kraken.com/u/security/api
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Binance.US (alternative — broader alt coverage, US-compliant)
# https://www.binance.us/en/usercenter/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Data sources (free tiers) ──

# CoinGecko (free, rate-limited at 10-30 req/min)
COINGECKO_API_KEY=

# CryptoQuant (paid, on-chain + exchange flows)
CRYPTOQUANT_API_KEY=

# Glassnode (paid, on-chain analytics)
GLASSNODE_API_KEY=

# ── Alerts (re-usable from stocks system) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# Optional: Telegram bot for instant alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Mode flag ──
# 'paper' = sandbox/no real orders; 'live' = real money (DON'T set live until 60+ paper trades)
TRADING_MODE=paper
