# Crypto Trading credentials
# Copy this file to .env and fill in real values. Never commit .env.

# ── Broker (pick ONE primary, optionally a second for cross-venue arb) ──

# Binance (PRIMARY — NZ-registered FSP, full public testnet, ~800 pairs)
# Live keys: https://www.binance.com/en-NZ -> Account -> API Management
# Testnet keys (separate, no KYC): https://testnet.binance.vision/
# Public market data works without any keys; only set these for live or testnet trading.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Set true to route LIVE orders to Binance Spot Testnet instead of mainnet.
# In paper mode this is ignored — paper uses local fills against mainnet ticks.
BINANCE_TESTNET=true

# Starting balance for paper mode (USDT)
PAPER_START_USDT=10000

# Independent Reserve (secondary — NZD-native, when fiat ramp matters)
# https://www.independentreserve.com/nz, then Settings -> API Keys
IR_API_KEY=
IR_API_SECRET=

# Kraken (secondary — futures demo, funding-rate signals)
# https://www.kraken.com/u/security/api
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Coinbase Advanced — sandbox-only; live unusable for NZ (no NZD on/off-ramp)
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_PASSPHRASE=

# ── Data sources (free tiers) ──

# CoinGecko (free, rate-limited at 10-30 req/min)
COINGECKO_API_KEY=

# CryptoQuant (paid, on-chain + exchange flows)
CRYPTOQUANT_API_KEY=

# Glassnode (paid, on-chain analytics)
GLASSNODE_API_KEY=

# ── Alerts (re-usable from stocks system) ──
# Daily reports + warning/critical alerts use ops/alerts.py which reads
# THESE three vars (Gmail SMTP). Use a Google App Password, NOT your
# account password. Generate at:
#   myaccount.google.com -> Security -> 2-Step Verification -> App passwords
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASS=

# Legacy SMTP vars (older modules; kept for compatibility)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# Optional: Telegram bot for instant alerts + /halt remote kill
# Create bot via @BotFather, get chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: SMS heartbeat-failure alerts (free for personal use)
# https://www.callmebot.com/ - register your phone, get APIKEY
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=

# ── Mode flag ──
# 'paper' = sandbox/no real orders; 'live' = real money (DON'T set live until 60+ paper trades)
TRADING_MODE=paper
